---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import ContactForm from '../components/ContactForm.astro';
import Contact from '../components/Contact.astro';
import Lightbox from '../components/Lightbox.astro';

/**
 * ADDING PHOTOS:
 * 1. Drop the image file into website/public/assets/
 * 2. Add a new entry to the `photos` array below
 * 3. Give it a filename (just the name, e.g. "job-panel-upgrade.jpg"),
 *    a label (shows as caption), and a category tag
 *
 * The tall: true flag makes a tile span two rows in the grid — use it
 * for portrait-orientation photos to avoid cropping.
 */

const photos = [

  // ── Outdoor & Porch ──────────────────────────────────────────
  { img: 'job-screened-porch-day.jpg',           label: 'Screened porch — fan & sconces',              category: 'Outdoor',    tall: true },
  { img: 'job-carport-lighting-night.jpg',        label: 'Carport recessed lighting — Brevard',         category: 'Outdoor' },
  { img: 'job-house-exterior-night.jpg',          label: 'Whole-house exterior — Hendersonville',       category: 'Outdoor' },
  { img: 'job-house-deck-day.jpg',                label: 'Deck wiring & under-deck — Etowah',           category: 'Outdoor',    tall: true },
  { img: 'job-screened-porch-wide.jpg',           label: 'Porch fan + barn lights — Saluda',            category: 'Outdoor' },
  { img: 'job-pavilion-recessed-night.jpeg',      label: 'Covered patio recessed lighting — Etowah',   category: 'Outdoor' },
  { img: 'job-porch-fan-sconces-night.jpeg',      label: 'Screened porch — fan + barn sconces — Etowah', category: 'Outdoor',  tall: true },
  { img: 'job-pavilion-ceiling-lights-day.jpeg',  label: 'Covered patio ceiling lighting — Etowah',    category: 'Outdoor' },
  { img: 'job-pavilion-porch-exterior-day.jpeg',  label: 'Covered patio + screened porch — Etowah',    category: 'Outdoor' },

  // ── Interior Lighting ────────────────────────────────────────
  { img: 'job-interior-living-pendant-fan.jpeg',  label: 'Open-concept living — pendant & fan',         category: 'Lighting' },
  { img: 'job-interior-dining-chandelier.jpeg',   label: 'Dining room beam chandelier',                 category: 'Lighting' },
  { img: 'job-bathroom-vanity-light.jpeg',        label: 'Bathroom vanity bar light',                   category: 'Lighting',   tall: true },
  { img: 'job-kitchen-pendants-recessed.jpeg',    label: 'Kitchen pendants + recessed lighting',        category: 'Lighting' },
  { img: 'job-tv-mount-fireplace.jpeg',           label: 'TV mount + media wiring — fireplace wall',    category: 'Lighting' },

  // ── Service & Panels ─────────────────────────────────────────
  { img: 'job-service-entrance-meter.jpeg',       label: 'Service entrance & meter install',            category: 'Service',    tall: true },
  { img: 'job-generator-inlet-outlet.jpeg',       label: 'Generator inlet — 30A transfer outlet',       category: 'Service',    tall: true },
  { img: 'job-panel-breakers-interior.jpeg',      label: 'Panel upgrade — breaker interior',            category: 'Service',    tall: true },
  { img: 'job-subpanel-new-install.jpeg',         label: 'New subpanel installation',                   category: 'Service',    tall: true },

  // ── Commercial ───────────────────────────────────────────────
  { img: 'job-commercial-conduit-panels.jpeg',    label: 'Commercial 480V — conduit & panels',          category: 'Commercial', tall: true },
  { img: 'job-commercial-contactor-wiring.jpeg',  label: 'Commercial contactor wiring',                 category: 'Commercial', tall: true },
  { img: 'job-commercial-structured-cabling.jpeg',label: 'Structured cabling — server room rough-in',   category: 'Commercial', tall: true },
  { img: 'job-commercial-cable-pull.jpeg',        label: 'Low-voltage cable pull — commercial',         category: 'Commercial' },

  // NOTE — photos held out of gallery (available in assets/):
  //   job-service-panel-closed.jpeg     — closed panel, not very visual
  //   job-generator-predator-9000.jpeg  — generator in garage, no install context
  //   job-wiring-rough-in-ceiling.jpeg  — rough-in wires, unfinished look
  //   job-commercial-cable-spool.jpeg   — similar to cable-pull above
  //   phil-onsite-planning.jpeg         — good for About section instead
];

// Collect unique category names for the filter buttons
const allCategories = ['All', ...new Set(photos.map(p => p.category))];
---

<Layout
  title="Our Work | White Squirrel Electric — Hendersonville, NC"
  description="Photos from residential and commercial electrical jobs across Hendersonville, Brevard, Asheville, and Western NC."
>
  <Nav />

  <main>

    <!-- Page header -->
    <section class="page-hero">
      <div class="section-inner page-hero-inner">
        <p class="page-eyebrow eyebrow">Recent work</p>
        <h1 class="page-h1">Wire I've pulled lately.</h1>
        <p class="page-sub">
          Residential, outdoor, and commercial jobs across Henderson County
          and western NC. Every photo is a real job Phil did himself.
        </p>
      </div>
    </section>

    <!-- Gallery -->
    <section class="gallery-section">
      <div class="section-inner">

        <!-- Filter bar -->
        <div class="filter-bar" id="filter-bar">
          {allCategories.map((cat, i) => (
            <button
              class={`filter-btn${i === 0 ? ' filter-btn--active' : ''}`}
              data-filter={cat}
            >
              {cat}
            </button>
          ))}
        </div>

        <!-- Grid -->
        <div class="gallery-grid" id="gallery-grid">
          {photos.map((p) => (
            <div
              class={`gallery-tile${p.tall ? ' gallery-tile--tall' : ''}`}
              data-category={p.category}
            >
              <img
                src={`/assets/${p.img}`}
                alt={p.label}
                loading="lazy"
                class="gallery-img"
              />
              <div class="gallery-caption">
                <span class="caption-tag">{p.category}</span>
                <span class="caption-label">{p.label}</span>
              </div>
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- CTA strip -->
    <section class="work-cta">
      <div class="section-inner work-cta-inner">
        <p class="work-cta-h">Have a job like one of these?</p>
        <a href="/#contact" class="btn-primary">Get in touch</a>
      </div>
    </section>

  </main>

  <ContactForm />
  <Contact />
  <Lightbox />
</Layout>

<script>
  // Category filter — show/hide tiles by data-category attribute
  const filterBar = document.getElementById('filter-bar');
  const grid      = document.getElementById('gallery-grid');

  filterBar?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.filter-btn');
    if (!btn) return;

    // Update active button
    filterBar.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('filter-btn--active'));
    btn.classList.add('filter-btn--active');

    const filter = btn.getAttribute('data-filter');
    grid?.querySelectorAll('.gallery-tile').forEach((tile) => {
      const el = tile as HTMLElement;
      if (filter === 'All' || el.dataset.category === filter) {
        el.style.display = '';
      } else {
        el.style.display = 'none';
      }
    });
  });
</script>

<style>
  /* ── Page hero ── */
  .page-hero {
    background: var(--ink);
    padding: 72px 0 56px;
  }

  .page-eyebrow {
    color: var(--gold);
    margin-bottom: 12px;
  }

  .page-h1 {
    font-family: 'Anton', sans-serif;
    font-size: clamp(48px, 7vw, 88px);
    line-height: 1;
    text-transform: uppercase;
    color: #fff;
    margin-bottom: 20px;
  }

  .page-sub {
    font-size: 18px;
    color: rgba(255,255,255,.65);
    line-height: 1.55;
    max-width: 560px;
  }

  /* ── Gallery section ── */
  .gallery-section {
    background: var(--paper);
    padding: 56px 0 80px;
  }

  /* Filter bar */
  .filter-bar {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }

  .filter-btn {
    font-family: 'Oswald', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--ink);
    background: transparent;
    border: 2px solid var(--ink);
    padding: 7px 16px;
    cursor: pointer;
    transition: background .15s, color .15s;
  }

  .filter-btn:hover,
  .filter-btn--active {
    background: var(--ink);
    color: #fff;
  }

  /* Grid */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 260px;
    gap: 16px;
  }

  .gallery-tile {
    position: relative;
    border: 3px solid var(--ink);
    overflow: hidden;
    background: #ddd; /* placeholder colour while image loads */
    cursor: pointer;
  }

  .gallery-tile--tall { grid-row: span 2; }

  .gallery-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform .35s ease;
  }

  .gallery-tile:hover .gallery-img { transform: scale(1.04); }

  /* Caption — slides up on hover */
  .gallery-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 32px 14px 12px;
    background: linear-gradient(to top, rgba(0,0,0,.75) 0%, transparent 100%);
    display: flex;
    flex-direction: column;
    gap: 3px;
    transform: translateY(4px);
    opacity: 0;
    transition: opacity .2s, transform .2s;
  }

  .gallery-tile:hover .gallery-caption {
    opacity: 1;
    transform: translateY(0);
  }

  .caption-tag {
    font-family: 'Oswald', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--gold);
  }

  .caption-label {
    font-family: 'Oswald', sans-serif;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: #fff;
  }

  /* ── CTA strip ── */
  .work-cta {
    background: var(--red);
    padding: 52px 0;
  }

  .work-cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }

  .work-cta-h {
    font-family: 'Anton', sans-serif;
    font-size: clamp(28px, 4vw, 48px);
    text-transform: uppercase;
    color: #fff;
    line-height: 1;
  }

  .btn-primary {
    font-family: 'Oswald', sans-serif;
    font-size: 16px;
    font-weight: 600;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: var(--red);
    background: #fff;
    padding: 14px 28px;
    box-shadow: 0 4px 0 rgba(0,0,0,.25);
    transition: box-shadow .15s, transform .15s;
    white-space: nowrap;
  }

  .btn-primary:hover {
    box-shadow: 0 1px 0 rgba(0,0,0,.25);
    transform: translateY(3px);
  }

  /* ── Responsive ── */
  @media (max-width: 1023px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 220px;
    }
    .gallery-tile--tall { grid-row: span 1; }
  }

  @media (max-width: 639px) {
    .page-hero { padding: 48px 0 40px; }
    .gallery-grid {
      grid-template-columns: 1fr;
      grid-auto-rows: 260px;
    }
    .gallery-caption { opacity: 1; transform: none; }
  }
</style>
