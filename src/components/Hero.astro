---
import { SITE } from '../config';
const { phoneDisplay: PHONE_DISPLAY, phoneTel: PHONE_TEL, licenseNum: LICENSE_NUM, yearsOnTools: YEARS_ON_TOOLS } = SITE;
---

<section class="hero">
  <div class="hero-inner">

    <!-- Left column: copy -->
    <div class="hero-copy">
      <div class="hero-badge">
        <span class="badge-dot"></span>
        NC GC Lic. {LICENSE_NUM} · Insured · Hendersonville, NC
      </div>

      <h1 class="hero-h1">
        Wired right.<br />
        As if it were<br />
        <span class="h1-script">my own house.</span>
      </h1>

      <p class="hero-body">
        One electrician. One truck. No subs, no answering service — just Phil Brisson,
        licensed NC general contractor, showing up and doing the work right.
      </p>

      <div class="hero-buttons">
        <a href={`tel:${PHONE_TEL}`} class="btn-primary">
          Call Phil — {PHONE_DISPLAY}
        </a>
        <a href="#contact" class="btn-secondary">
          Or send a note →
        </a>
      </div>

      <div class="hero-trust">
        <span>★★★★★</span>
        <span>NC GC Licensed</span>
        <span class="trust-divider">·</span>
        <span>{YEARS_ON_TOOLS} yrs on the tools</span>
      </div>
    </div>

    <!-- Right column: mascot -->
    <div class="hero-mascot-wrap">
      <div class="sunburst" aria-hidden="true"></div>
      <!-- mascot-figure wraps image + sticker so the sticker sits below the logo, not over it -->
      <div class="mascot-figure">
        <img
          src="/assets/logo-mascot.png"
          alt="White Squirrel Electric mascot"
          class="hero-mascot"
          width="540"
        />
        <div class="hero-sticker" aria-hidden="true">
          Fair prices.<br />Honest work.
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .hero {
    background:
      radial-gradient(ellipse at 30% 0%, #2c5fb5 0%, var(--navy) 55%, #0d1d3d 100%);
    position: relative;
    overflow: hidden;
  }

  /* Halftone dot overlay */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255,255,255,.07) 1.2px, transparent 1.4px);
    background-size: 14px 14px;
    pointer-events: none;
  }

  .hero-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 64px 48px 56px;
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 32px;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  /* ── Badge ── */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--red);
    color: #fff;
    font-family: 'Oswald', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: .12em;
    text-transform: uppercase;
    padding: 6px 14px;
    box-shadow: 0 2px 0 rgba(0,0,0,.35);
    margin-bottom: 24px;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #fff;
    flex-shrink: 0;
  }

  /* ── H1 ── */
  .hero-h1 {
    font-family: 'Anton', sans-serif;
    font-size: clamp(56px, 8vw, 104px);
    line-height: .92;
    letter-spacing: -.01em;
    text-transform: uppercase;
    color: #fff;
    margin-bottom: 28px;
  }

  .h1-done {
    color: var(--gold);
  }

  .h1-script {
    font-family: 'Pacifico', cursive;
    font-size: clamp(48px, 7vw, 92px);
    color: var(--red-soft);
    text-transform: none;
    letter-spacing: 0;
    display: inline-block;
    transform: rotate(-2deg);
  }

  /* ── Body ── */
  .hero-body {
    font-size: 19px;
    color: rgba(255,255,255,.86);
    margin-bottom: 36px;
    max-width: 480px;
    line-height: 1.55;
  }

  /* ── Buttons ── */
  .hero-buttons {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }

  .btn-primary {
    font-family: 'Oswald', sans-serif;
    font-size: 18px;
    font-weight: 600;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: #fff;
    background: var(--red);
    padding: 16px 28px;
    box-shadow: 0 5px 0 var(--red-shadow);
    transition: box-shadow .15s, transform .15s;
  }

  .btn-primary:hover {
    box-shadow: 0 2px 0 var(--red-shadow);
    transform: translateY(3px);
  }

  .btn-secondary {
    font-family: 'Oswald', sans-serif;
    font-size: 16px;
    font-weight: 500;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: rgba(255,255,255,.85);
    border: 2px solid rgba(255,255,255,.4);
    padding: 14px 24px;
    transition: border-color .15s, color .15s;
  }

  .btn-secondary:hover {
    border-color: #fff;
    color: #fff;
  }

  /* ── Trust strip ── */
  .hero-trust {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: 'Oswald', sans-serif;
    font-size: 13px;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: rgba(255,255,255,.65);
  }

  .trust-divider { opacity: .4; }

  /* ── Mascot column ── */
  .hero-mascot-wrap {
    position: relative;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }

  /* Animated sunburst */
  .sunburst {
    position: absolute;
    inset: -60px;
    background: conic-gradient(
      from 0deg,
      var(--red) 0deg 10deg,
      transparent 10deg 30deg,
      var(--red) 30deg 40deg,
      transparent 40deg 60deg,
      var(--red) 60deg 70deg,
      transparent 70deg 90deg,
      var(--red) 90deg 100deg,
      transparent 100deg 120deg,
      var(--red) 120deg 130deg,
      transparent 130deg 150deg,
      var(--red) 150deg 160deg,
      transparent 160deg 180deg,
      var(--red) 180deg 190deg,
      transparent 190deg 210deg,
      var(--red) 210deg 220deg,
      transparent 220deg 240deg,
      var(--red) 240deg 250deg,
      transparent 250deg 270deg,
      var(--red) 270deg 280deg,
      transparent 280deg 300deg,
      var(--red) 300deg 310deg,
      transparent 310deg 330deg,
      var(--red) 330deg 340deg,
      transparent 340deg 360deg
    );
    opacity: .35;
    border-radius: 50%;
    animation: spin 90s linear infinite;
    -webkit-mask-image: radial-gradient(ellipse 60% 60% at 50% 50%, black 30%, transparent 75%);
    mask-image: radial-gradient(ellipse 60% 60% at 50% 50%, black 30%, transparent 75%);
  }

  /* mascot-figure: a column wrapper sized to the image so the sticker
     sits naturally below the logo wordmark rather than overlapping it */
  .mascot-figure {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    max-width: 540px;
    width: 100%;
  }

  .hero-mascot {
    width: 100%;
    filter: drop-shadow(0 24px 30px rgba(0,0,0,.55));
  }

  /* Sticker — lives below the logo, not on top of it */
  .hero-sticker {
    margin-top: 8px;
    margin-left: 4px;
    font-family: 'Caveat Brush', cursive;
    font-size: 22px;
    line-height: 1.3;
    color: var(--ink);
    background: var(--gold);
    padding: 10px 14px;
    transform: rotate(-6deg);
    box-shadow: 4px 4px 0 var(--ink);
  }

  /* ── Responsive ── */
  @media (max-width: 1023px) {
    .hero-inner {
      grid-template-columns: 1fr;
      padding: 48px 32px 40px;
    }
    .hero-mascot-wrap { order: -1; max-width: 340px; margin: 0 auto; }
    .sunburst { inset: -20px; }
  }

  @media (max-width: 639px) {
    .hero-h1 { font-size: 56px; }
    .h1-script { font-size: 48px; }
    .hero-mascot { max-width: 85%; margin: 0 auto; }
    .hero-sticker { font-size: 18px; }
  }
</style>
