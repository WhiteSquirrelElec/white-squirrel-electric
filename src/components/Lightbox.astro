---
// Lightbox overlay — import this into any page/component that has .gallery-tile elements.
// Clicking any .gallery-tile opens the lightbox. Prev/next arrows (or ← → keys) navigate
// through all tiles on the page. Close with X, backdrop click, or Escape.
---

<div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Photo viewer" hidden>
  <div class="lightbox-backdrop" id="lightbox-backdrop"></div>
  <button class="lightbox-close" id="lightbox-close" aria-label="Close photo">✕</button>
  <button class="lightbox-arrow lightbox-arrow--prev" id="lightbox-prev" aria-label="Previous photo">&#8592;</button>
  <button class="lightbox-arrow lightbox-arrow--next" id="lightbox-next" aria-label="Next photo">&#8594;</button>
  <figure class="lightbox-figure">
    <img class="lightbox-img" id="lightbox-img" src="" alt="" />
    <figcaption class="lightbox-caption" id="lightbox-caption"></figcaption>
  </figure>
</div>

<script>
  const lightbox         = document.getElementById('lightbox')!;
  const lightboxImg      = document.getElementById('lightbox-img') as HTMLImageElement;
  const lightboxCaption  = document.getElementById('lightbox-caption')!;
  const lightboxClose    = document.getElementById('lightbox-close')!;
  const lightboxBackdrop = document.getElementById('lightbox-backdrop')!;
  const btnPrev          = document.getElementById('lightbox-prev')!;
  const btnNext          = document.getElementById('lightbox-next')!;

  // Collect all gallery images once at load time.
  // On the /work page some tiles are hidden by the category filter, so we
  // re-collect visible tiles each time the lightbox opens so arrows only
  // cycle through what's currently showing.
  type GalleryItem = { src: string; alt: string };
  let items: GalleryItem[] = [];
  let currentIndex = 0;

  function getVisibleItems(): GalleryItem[] {
    return Array.from(document.querySelectorAll<HTMLElement>('.gallery-tile'))
      .filter(tile => tile.style.display !== 'none')
      .map(tile => {
        const img = tile.querySelector('img');
        return img ? { src: img.src, alt: img.alt } : null;
      })
      .filter(Boolean) as GalleryItem[];
  }

  function showItem(index: number) {
    if (!items.length) return;
    // Wrap around at either end
    currentIndex = (index + items.length) % items.length;
    const item = items[currentIndex];
    lightboxImg.src = item.src;
    lightboxImg.alt = item.alt;
    lightboxCaption.textContent = item.alt;
    // Hide arrows when there's only one photo
    const showArrows = items.length > 1;
    btnPrev.style.display = showArrows ? '' : 'none';
    btnNext.style.display = showArrows ? '' : 'none';
  }

  function openLightbox(clickedSrc: string) {
    items = getVisibleItems();
    const idx = items.findIndex(it => it.src === clickedSrc);
    lightbox.removeAttribute('hidden');
    document.body.style.overflow = 'hidden';
    showItem(idx >= 0 ? idx : 0);
    lightboxClose.focus();
  }

  function closeLightbox() {
    lightbox.setAttribute('hidden', '');
    document.body.style.overflow = '';
    lightboxImg.src = '';
  }

  // Open: click any .gallery-tile
  document.addEventListener('click', (e) => {
    const tile = (e.target as HTMLElement).closest('.gallery-tile');
    if (!tile) return;
    const img = tile.querySelector('img');
    if (!img) return;
    openLightbox(img.src);
  });

  // Arrows
  btnPrev.addEventListener('click', () => showItem(currentIndex - 1));
  btnNext.addEventListener('click', () => showItem(currentIndex + 1));

  // Close
  lightboxClose.addEventListener('click', closeLightbox);
  lightboxBackdrop.addEventListener('click', closeLightbox);

  // Keyboard: Escape closes, ← → navigate
  document.addEventListener('keydown', (e) => {
    if (lightbox.hasAttribute('hidden')) return;
    if (e.key === 'Escape')      closeLightbox();
    if (e.key === 'ArrowLeft')   showItem(currentIndex - 1);
    if (e.key === 'ArrowRight')  showItem(currentIndex + 1);
  });
</script>

<style>
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 500;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox[hidden] { display: none; }

  /* Dark backdrop */
  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.88);
    cursor: pointer;
  }

  /* Image + caption */
  .lightbox-figure {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    max-width: 82vw; /* narrower than before to leave room for arrows */
    max-height: 90vh;
  }

  .lightbox-img {
    display: block;
    max-width: 82vw;
    max-height: 80vh;
    object-fit: contain;
    border: 3px solid #fff;
    box-shadow: 0 8px 48px rgba(0, 0, 0, 0.6);
  }

  .lightbox-caption {
    font-family: 'Oswald', sans-serif;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.75);
    text-align: center;
  }

  /* Close button */
  .lightbox-close {
    position: absolute;
    top: 20px;
    right: 24px;
    z-index: 2;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 2px solid rgba(255, 255, 255, 0.5);
    color: #fff;
    font-size: 20px;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
  }

  .lightbox-close:hover {
    background: rgba(255, 255, 255, 0.15);
    border-color: #fff;
  }

  /* Prev / Next arrows — sit on the sides, vertically centered */
  .lightbox-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.45);
    border: 2px solid rgba(255, 255, 255, 0.4);
    color: #fff;
    font-size: 26px;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
    /* Prevent backdrop click from firing when arrow is clicked */
    pointer-events: all;
  }

  .lightbox-arrow:hover {
    background: rgba(0, 0, 0, 0.7);
    border-color: #fff;
  }

  .lightbox-arrow--prev { left: 20px; }
  .lightbox-arrow--next { right: 20px; }

  @media (max-width: 639px) {
    .lightbox-close { top: 12px; right: 12px; }
    .lightbox-arrow { width: 40px; height: 40px; font-size: 20px; }
    .lightbox-arrow--prev { left: 8px; }
    .lightbox-arrow--next { right: 8px; }
    .lightbox-figure { max-width: 88vw; }
    .lightbox-img { max-width: 88vw; }
  }
</style>
