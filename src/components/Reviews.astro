---
import { SITE } from '../config';
const GOOGLE_URL = SITE.googleBusiness;
const REVIEW_URL = SITE.googleReviewLink;

// ✅ Real reviews — rotating highlight carousel.
// Showing a punchy pull-quote from each; full text preserved in comments.
// Future: wire to Google Places API to pull live from Google Business.
const reviews = [
  {
    highlight: "One of the best contractors I've ever worked with — I would have happily paid him more than he charged.",
    // Full: "Phil did all the outdoor wiring, conduit, lighting, and fan installations for a massive 2-level deck/patio I had built in 2025. He coordinated and worked well with my other contractors to make sure all the electrical work was planned and done without causing any rework or delays. He was extremely responsive, friendly, professional, and always left the space better than when he showed up. One of the best contractors I've ever worked with — I would have happily paid him more than he charged."
    name: 'John B.',
    location: 'Etowah, NC',
  },
  {
    highlight: "It's hard to find someone this reliable and thorough these days.",
    // Full: "I highly recommend Phil & this company to anyone looking for quality work at a fair price. He takes a lot of pride in what he does, and it really shows in the finished work. Everything was clean, detailed, and professionally done from start to finish. He has a great personality, communicates well, and treats every project with care and attention to detail. It's hard to find someone this reliable and thorough these days. I would absolutely recommend him to anyone I know. Thank you Phill!!!"
    name: 'Katlyn Fonseca',
    location: 'Google Review',
  },
  {
    highlight: "He is so polite and professional! I will call him again for all of my electrical needs!",
    // Full: "Phillip did a fantastic job! He is so polite and professional! I will call him again for all of my electrical needs!"
    name: 'Alyssa Hatfield',
    location: 'Google Review',
  },
  {
    highlight: "Professional, on time, and excellent work — he explained everything before leaving and made sure it was all working properly.",
    // Full: "I had a great experience with this electrician installing my Ring floodlight camera in my driveway. He was professional, on time, and did an excellent job with the installation. Everything was mounted securely, wired neatly, and set up perfectly. He also made sure the camera angle and motion detection were positioned just right for maximum coverage. The floodlight works great, and the whole setup looks clean and professional. I really appreciated how he explained everything before leaving and made sure it was all working properly. Highly recommend for anyone needing electrical work or security camera installation!"
    name: 'Daniel Fonseca',
    location: 'Google Review',
  },
];
---

<section class="reviews" id="reviews">
  <div class="section-inner">

    <div class="reviews-header">
      <p class="eyebrow reviews-eyebrow">What folks say</p>
      <h2 class="reviews-h2">Good word travels.</h2>
    </div>

    <div class="reviews-carousel" aria-live="polite">
      {reviews.map((r, i) => (
        <div class="review-slide" data-index={i} aria-hidden={i !== 0 ? 'true' : 'false'}>
          <div class="review-open-quote">&ldquo;</div>
          <p class="review-highlight">{r.highlight}</p>
          <div class="review-attribution">
            <span class="review-stars">★★★★★</span>
            <span class="review-name">{r.name}</span>
            <span class="review-location">{r.location}</span>
          </div>
        </div>
      ))}
    </div>

    <div class="reviews-dots" aria-hidden="true">
      {reviews.map((_, i) => (
        <button class="reviews-dot" data-dot={i} aria-label={`Review ${i + 1}`}></button>
      ))}
    </div>

    <div class="reviews-actions">
      {GOOGLE_URL && (
        <a href={GOOGLE_URL} target="_blank" rel="noopener noreferrer" class="google-link">
          ★ Read our reviews on Google
        </a>
      )}
      {REVIEW_URL && (
        <a href={REVIEW_URL} target="_blank" rel="noopener noreferrer" class="google-link google-link--filled">
          ✎ Leave us a review!
        </a>
      )}
    </div>

  </div>
</section>

<style>
  .reviews {
    background: linear-gradient(160deg, var(--red) 0%, #a4111e 100%);
    padding: var(--section-pad-v) 0;
    position: relative;
    overflow: hidden;
  }

  /* Halftone overlay */
  .reviews::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255,255,255,.06) 1.2px, transparent 1.4px);
    background-size: 16px 16px;
    pointer-events: none;
  }

  .section-inner { position: relative; z-index: 1; }

  /* Header */
  .reviews-header { margin-bottom: 56px; }

  .reviews-eyebrow {
    color: var(--gold);
    margin-bottom: 12px;
  }

  .reviews-h2 {
    font-family: 'Anton', sans-serif;
    font-size: clamp(40px, 5vw, 64px);
    line-height: 1;
    text-transform: uppercase;
    color: #fff;
  }

  /* Carousel container — fixed height so slides don't shift layout */
  .reviews-carousel {
    position: relative;
    min-height: 220px;
    display: flex;
    align-items: center;
    max-width: 820px;
    margin: 0 auto;
  }

  /* Individual slides — stacked, fading in/out */
  .review-slide {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.9s ease;
    pointer-events: none;
  }

  .review-slide.is-active {
    opacity: 1;
    pointer-events: auto;
  }

  /* Big opening quote mark */
  .review-open-quote {
    font-family: 'Anton', sans-serif;
    font-size: 80px;
    line-height: 0.6;
    color: rgba(0, 0, 0, 0.75);
    margin-bottom: 16px;
    user-select: none;
  }

  /* The pull-quote itself */
  .review-highlight {
    font-family: 'Inter', sans-serif;
    font-size: clamp(22px, 2.8vw, 34px);
    font-style: italic;
    font-weight: 400;
    line-height: 1.4;
    color: var(--ink);
    margin-bottom: 28px;
  }

  /* Attribution row */
  .review-attribution {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
  }

  .review-stars {
    color: var(--gold);
    font-size: 18px;
    letter-spacing: 2px;
  }

  .review-name {
    font-family: 'Oswald', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: #fff;
  }

  .review-location {
    font-family: 'Oswald', sans-serif;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
  }

  /* Dot indicators */
  .reviews-dots {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-top: 48px;
    margin-bottom: 8px;
  }

  .reviews-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.3);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background .3s, transform .3s;
  }

  .reviews-dot.is-active {
    background: #fff;
    transform: scale(1.25);
  }

  /* Action buttons */
  .reviews-actions {
    margin-top: 40px;
    display: flex;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .google-link {
    display: inline-block;
    font-family: 'Oswald', sans-serif;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: #fff;
    border: 2px solid rgba(255, 255, 255, 0.5);
    padding: 12px 28px;
    transition: border-color .15s, background .15s;
  }

  .google-link:hover {
    border-color: #fff;
    background: rgba(255, 255, 255, 0.1);
  }

  /* Filled variant for the "Leave a review" CTA */
  .google-link--filled {
    background: #fff;
    border-color: #fff;
    color: var(--red);
  }

  .google-link--filled:hover {
    background: rgba(255, 255, 255, 0.88);
    border-color: rgba(255, 255, 255, 0.88);
  }

  /* Responsive */
  @media (max-width: 639px) {
    .reviews-carousel { min-height: 280px; }
    .review-highlight { font-size: clamp(22px, 6vw, 30px); }
  }
</style>

<script>
  (function () {
    const slides = Array.from(document.querySelectorAll('.review-slide'));
    const dots   = Array.from(document.querySelectorAll('.reviews-dot'));
    if (!slides.length) return;

    let current = 0;
    let timer;

    function show(index) {
      slides[current].classList.remove('is-active');
      slides[current].setAttribute('aria-hidden', 'true');
      dots[current].classList.remove('is-active');

      current = index;

      slides[current].classList.add('is-active');
      slides[current].setAttribute('aria-hidden', 'false');
      dots[current].classList.add('is-active');
    }

    function next() {
      show((current + 1) % slides.length);
    }

    function startTimer() {
      timer = setInterval(next, 6000);
    }

    function resetTimer() {
      clearInterval(timer);
      startTimer();
    }

    // Init
    show(0);
    startTimer();

    // Clicking a dot jumps to that slide and resets the auto-advance timer
    dots.forEach(function(dot, i) {
      dot.addEventListener('click', function() {
        show(i);
        resetTimer();
      });
    });
  })();
</script>
